Bootstrap: docker
From: ubuntu:22.04

%environment
    export DEBIAN_FRONTEND=noninteractive
    export PATH="/root/.cargo/bin:/root/.ghcup/bin:${PATH}"

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ca-certificates python3.10 python3.10-venv \
        python3-pip python-is-python3 wget git build-essential jq locales cmake \
    && rm -rf /var/lib/apt/lists/*

    curl https://sh.rustup.rs -sSf | sh -s -- -y
    . "$HOME/.cargo/env"

    apt-get update && apt-get install -y ocaml ocamlbuild \
    && rm -rf /var/lib/apt/lists/*

    apt-get update && apt-get install -y libgmp-dev \
    && rm -rf /var/lib/apt/lists/*

    curl --proto '=https' --tlsv1.2 -sSf https://get-ghcup.haskell.org | \
        BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_ADJUST_BASHRC=1 sh

    export PATH="/root/.ghcup/bin:/root/.cargo/bin:${PATH}"

    git clone https://github.com/CodeClash-ai/Halite2.git /workspace \
    && cd /workspace \
    && git remote set-url origin https://github.com/CodeClash-ai/Halite2.git

    cd /workspace/environment && cmake . && make

%labels
    Author CodeClash
