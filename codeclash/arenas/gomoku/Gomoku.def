Bootstrap: docker
From: ubuntu:22.04

%environment
    export DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update \
    && apt-get install -y --no-install-recommends \
        curl ca-certificates python3.10 python3.10-venv \
        python3-pip python-is-python3 wget git build-essential jq locales \
    && rm -rf /var/lib/apt/lists/*

    git clone https://github.com/CodeClash-ai/Gomoku.git /workspace \
    && cd /workspace \
    && git remote set-url origin https://github.com/CodeClash-ai/Gomoku.git

%labels
    Author CodeClash
